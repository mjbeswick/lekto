{
  "name": "lekto",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "prebuild": "npm run generate:icons",
    "build": "tsc -b && vite build",
    "android:build": "npm run build && npx cap sync android && cd android && ./gradlew clean assembleRelease && cp app/build/outputs/apk/release/app-release-unsigned.apk ../lekto.apk",
    "android:push": "npm run build && npx cap sync android && npx cap run android",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop:build": "npm run build && (bun run electrobun build --env=stable || test -d build/stable-macos-arm64/Lekto.app)",
    "desktop:dev": "bun desktop/bun/index.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@fontsource/lexend": "^5.2.11",
    "@fontsource/merriweather": "^5.2.11",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "file-icon-vectors": "^1.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electrobun": "^1.16.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
